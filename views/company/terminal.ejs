<% layout('./layouts/dashboard') %>
    <link rel="stylesheet" href="/css/a.css">
    <link rel="stylesheet" href="/css/terminal.css">

    <div class="terminal-container">

        <div class="terminal-header">
            <h1><i class="fa-solid fa-microphone"></i> Meeting Terminal</h1>
            <p><i class="fa-solid fa-building"></i> Company Dashboard</p>
        </div>

        <% const meetingsSorted=[...meetings].sort((a, b)=>
            new Date(b.uploadedAt) - new Date(a.uploadedAt)
            );

            const latest = meetingsSorted[0];
            const others = meetingsSorted
            .slice(1)
            .filter(m => m.transcribeStatus === "pending");
            %>

            <% if (latest) { %>
                <div class="hero-card">
                    <div class="hero-badge">
                        <i></i> Latest Upload
                    </div>

                    <div class="hero-filename">
                        <i class="fa-solid fa-file-audio"></i>
                        <%= latest.fileName %>
                    </div>

                    <div class="hero-player-row">
                        <audio controls>
                            <source src="<%= latest.fileUrl %>" type="audio/mpeg">
                        </audio>
                        <a href="/meetings/<%= latest._id %>/transcribe" class="btn btn-primary btn-transcribe">
                            <i class="fa-solid fa-waveform-lines"></i> Transcribe
                        </a>
                    </div>

                    <div class="hero-meta">
                        <span><i class="fa-solid fa-database"></i>
                            <%= latest.fileSize %> MB
                        </span>

                    </div>
                </div>
                <% } %>

                    <% if (others.length> 0) { %>
                        <p class="section-label">Previous Recordings</p>

                        <div class="meetings-grid">
                            <% others.forEach(meeting=> { %>
                                <div class="meeting-card">
                                    <div class="card-filename">
                                        <i class="fa-solid fa-file-audio"></i>
                                        <%= meeting.fileName %>
                                    </div>



                                    <div class="card-footer">
                                        <div class="card-meta">
                                            <span><i class="fa-solid fa-database"></i>
                                                <%= meeting.fileSize %> MB
                                            </span>

                                        </div>

                                    </div>
                                </div>
                                <% }) %>
                        </div>
                        <% } %>

    </div>