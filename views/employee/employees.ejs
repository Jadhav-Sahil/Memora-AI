<% layout('./layouts/dashboard') %>

    <div class="employee-container">

        <h2 class="page-title">Team Members</h2>

        <% if (employees && employees.length> 0) { %>

            <div class="employee-grid">

                <% employees.forEach(emp=> { %>

                    <div class="employee-card">

                        <!-- Profile Section -->
                        <div class="employee-avatar">
                            <%= emp.name.charAt(0).toUpperCase() %>
                        </div>

                        <div class="employee-info">
                            <h3 class="employee-name">
                                <%= emp.name %>
                            </h3>
                            <p class="employee-email">
                                <%= emp.email %>
                            </p>
                            <p class="employee-role">
                                <%= emp.role %>
                            </p>

                            <% if (emp.isActive) { %>
                                <span class="status active">Active</span>
                                <% } else { %>
                                    <span class="status inactive">Inactive</span>
                                    <% } %>
                        </div>

                        <!-- ACTIONS -->
                        <div class="employee-actions">

                            <% if (emp.isActive) { %>

                                <form action="/employee/deactivate/<%= emp._id %>" method="POST"
                                    class="deactivate-form">
                                    <button class="deactivate-btn" type="submit">
                                        <i class="bi bi-person-dash"></i>
                                        Deactivate
                                    </button>
                                </form>

                                <% } else { %>

                                    <button class="btn disabled-btn" disabled>
                                        Deactivated
                                    </button>

                                    <% } %>

                        </div>

                    </div>

                    <% }) %>

            </div>

            <% } else { %>

                <p class="empty-text">No employees found for this company.</p>

                <% } %>

    </div>
    <script src="/js/employees.js"></script>

    <script src="/socket.io/socket.io.js"></script>

    <script src="/socket.io/socket.io.js"></script>