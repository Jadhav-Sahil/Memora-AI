<% layout('./layouts/boilerplate') %>

    <title>Forgot Password - Memora AI</title>

    <div class="auth-wrapper">
        <div class="auth-card">

            <div class="auth-header">
                <a href="/" class="lp-logo" style="justify-content:center;margin-bottom:1rem;">
                    <i class="fa-solid fa-brain"></i> Memora AI
                </a>

                <h2>Reset Password</h2>

                <p>
                    Enter your registered email address and verify it
                    using OTP before resetting your password.
                </p>
            </div>

            <% if(success && success.length) { %>
                <div class="alert alert-success">
                    <%= success[0] %>
                </div>
                <% } %>

                    <% if(error && error.length) { %>
                        <div class="alert alert-danger">
                            <%= error[0] %>
                        </div>
                        <% } %>

                            <div id="alertBox" style="display:none;margin-bottom:15px;"></div>

                            <form id="forgotPasswordForm" action="/employee/forgot-password" method="POST">

                                <input type="hidden" id="otpVerifiedField" name="otpVerified" value="false">

                                <!-- Email -->
                                <div class="form-group">
                                    <label class="form-label">
                                        Registered Email Address
                                    </label>

                                    <input type="email" name="email" id="email" class="form-input form-control"
                                        placeholder="you@example.com" autocomplete="email" required>
                                </div>

                                <!-- Send OTP -->
                                <button type="button" id="sendOtpBtn" class="btn btn-primary w-100">
                                    Send Verification Code
                                </button>

                                <!-- OTP SECTION -->
                                <div id="otpSection" style="
                    display:none;
                    margin-top:20px;
                    padding-top:20px;
                    border-top:1px solid #e5e7eb;
                ">

                                    <div class="alert alert-info">
                                        Verification code sent to
                                        <strong id="sentEmail"></strong>
                                    </div>

                                    <div class="form-group">
                                        <label class="form-label">
                                            Verification Code
                                        </label>

                                        <input type="text" id="otpInput" class="form-input form-control" maxlength="6"
                                            placeholder="Enter 6-digit OTP">
                                    </div>

                                    <button type="button" id="verifyOtpBtn" class="btn btn-success w-100">
                                        Verify OTP
                                    </button>

                                    <div style="margin-top:15px;text-align:center;">

                                        <button type="button" id="resendBtn" class="btn btn-link" disabled>
                                            Resend OTP
                                        </button>

                                        <span id="timerText">(60s)</span>

                                    </div>

                                </div>

                                <!-- VERIFIED -->
                                <div id="verifiedBox" class="alert alert-success" style="display:none;margin-top:20px;">
                                    OTP verified successfully.
                                </div>

                                <!-- PASSWORD SECTION -->
                                <div id="passwordSection" style="
                    display:none;
                    margin-top:20px;
                    padding-top:20px;
                    border-top:1px solid #e5e7eb;
                ">

                                    <div class="form-group">
                                        <label class="form-label">
                                            New Password
                                        </label>

                                        <input type="password" name="password" id="password"
                                            class="form-input form-control" minlength="8">
                                    </div>

                                    <div class="form-group">
                                        <label class="form-label">
                                            Confirm Password
                                        </label>

                                        <input type="password" name="c_password" id="c_password"
                                            class="form-input form-control" minlength="8">
                                    </div>

                                    <button type="submit" id="resetBtn" class="btn btn-primary w-100">
                                        Reset Password
                                    </button>

                                </div>

                            </form>

                            <div class="auth-footer-text" style="margin-top:20px;">
                                Remember your password?
                                <a href="/employee-login">Sign In</a>
                            </div>

        </div>
    </div>

    <script src="/js/forgot_1.js"></script>